---
const nav = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#nosotros', label: 'Nosotros' },
  { href: '#eventos', label: 'Eventos' },
  { href: '#launcher', label: 'Launcher' },
];
const social = [
  { href: '#', label: 'Discord' },
  { href: '#', label: 'YouTube' },
  { href: '#', label: 'Twitter / X' },
];
const resources = [
  { href: '#launcher', label: 'Descargar Client' },
  { href: '#', label: 'Reglas' },
  { href: '#', label: 'Contacto' },
];
---

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">BLOCK<span>FOR</span>SALE</div>
        <div class="footer-sub">Hardcore Survival Events — Minecraft</div>
        <p class="footer-about">
          Creamos servidores y organizamos eventos de Minecraft desde hace tiempo. Survival, torneos, UHC y mucho más.
        </p>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <h5>Navegación</h5>
          <ul>{nav.map(({ href, label }) => <li><a href={href}>{label}</a></li>)}</ul>
        </div>
        <div class="footer-col">
          <h5>Comunidad</h5>
          <ul>{social.map(({ href, label }) => <li><a href={href}>{label}</a></li>)}</ul>
        </div>
        <div class="footer-col">
          <h5>Recursos</h5>
          <ul>{resources.map(({ href, label }) => <li><a href={href}>{label}</a></li>)}</ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copy">© 2026 BlockForSale Events. Todos los derechos reservados.</div>
      <div class="footer-version">v1.0.1 — RELEASE</div>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 72px 0 40px;
    border-top: 0.5px solid var(--border);
    background: var(--black);
    position: relative;
    z-index: 1;
  }

  footer::before {
    content: '';
    position: absolute;
    top: -1px; left: 30%; right: 30%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--red), transparent);
    opacity: 0.5;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    margin-bottom: 56px;
    align-items: start;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 30px;
    letter-spacing: 3px;
    color: var(--text);
    filter: drop-shadow(0 0 16px rgba(204,27,27,0.3));
    margin-bottom: 6px;
  }

  .footer-logo span { color: var(--red); }

  .footer-sub {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 20px;
  }

  .footer-about {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 280px;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .footer-col h5 {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 18px;
  }

  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 11px; }

  .footer-col a {
    text-decoration: none;
    font-size: 13px;
    color: var(--text-muted);
    transition: color 0.2s;
    letter-spacing: 0.2px;
  }

  .footer-col a:hover { color: var(--text); }

  .footer-bottom {
    border-top: 0.5px solid var(--border);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.3px;
  }

  .footer-version {
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 1px;
    font-family: 'Courier New', monospace;
  }

  @media (max-width: 900px) {
    .footer-inner { padding: 0 24px; }
    .footer-top { grid-template-columns: 1fr; gap: 40px; }
    .footer-cols { grid-template-columns: repeat(2, 1fr); }
  }
</style>
