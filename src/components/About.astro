---
const pillars = [
  {
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
    title: 'Servidores a medida',
    desc: 'Montamos y configuramos servidores para cada tipo de evento. Cada mundo, pensado al detalle.',
  },
  {
    icon: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
    title: 'Eventos de alto nivel',
    desc: 'De survival vanilla a UHC, torneos PvP y minijuegos. Siempre con la mejor experiencia posible.',
  },
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    title: 'Comunidad activa',
    desc: 'Una base de jugadores que vuelve evento tras evento. Nos importa la experiencia de cada uno.',
  },
  {
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
    title: 'Experiencia comprobada',
    desc: 'Llevamos tiempo organizando, fallando, aprendiendo y mejorando. Sabemos lo que funciona.',
  },
];

const types = [
  { label: 'Survival', icon: '🌲' },
  { label: 'Hardcore', icon: '💀' },
  { label: 'UHC', icon: '⚔️' },
  { label: 'Torneos PvP', icon: '🏆' },
  { label: 'Minijuegos', icon: '🎮' },
  { label: 'Eventos custom', icon: '⚡' },
];
---

<section id="nosotros">
  <div class="section-inner">

    <div class="about-top reveal">
      <div>
        <span class="section-tag">Quiénes somos</span>
        <h2 class="section-title">MÁS QUE<br /><span>UN SERVIDOR.</span></h2>
      </div>
      <p class="about-lead">
        BlockForSale Events nació para hacer algo simple: crear la mejor experiencia posible dentro de Minecraft. No nos limitamos a un solo formato — organizamos lo que sea, cuando sea, bien hecho.
      </p>
    </div>

    <div class="pillars reveal reveal-delay">
      {pillars.map(({ icon, title, desc }) => (
        <div class="pillar">
          <div class="pillar-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icon} />
            </svg>
          </div>
          <h4>{title}</h4>
          <p>{desc}</p>
        </div>
      ))}
    </div>

    <div class="types-row reveal reveal-delay-2">
      <p class="types-label">Lo que hacemos</p>
      <div class="types-list">
        {types.map(({ label }) => (
          <div class="type-pill">{label}</div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  section {
    padding: 130px 0;
    position: relative;
    z-index: 1;
  }

  .about-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 72px;
  }

  .section-title span { color: var(--red); }

  .about-lead {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.9;
    padding-top: 8px;
  }

  /* Pillars */
  .pillars {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 0.5px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 48px;
  }

  .pillar {
    background: var(--surface);
    padding: 32px 28px;
    transition: background 0.25s;
    position: relative;
    overflow: hidden;
  }

  .pillar::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }

  .pillar:hover { background: #1a1a1a; }
  .pillar:hover::before { transform: scaleX(1); }

  .pillar-icon {
    width: 38px; height: 38px;
    border: 0.5px solid var(--border-red);
    background: var(--red-subtle);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
    color: var(--red);
  }

  .pillar-icon svg { width: 16px; height: 16px; }

  .pillar h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 8px;
    letter-spacing: 0.3px;
  }

  .pillar p {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* Types */
  .types-row {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .types-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    flex-shrink: 0;
  }

  .types-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .type-pill {
    border: 0.5px solid var(--border);
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    padding: 6px 14px;
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    cursor: default;
  }

  .type-pill:hover {
    border-color: var(--border-red);
    color: var(--text);
    background: var(--red-subtle);
  }

  @media (max-width: 900px) {
    .about-top { grid-template-columns: 1fr; gap: 24px; }
    .pillars { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .pillars { grid-template-columns: 1fr; }
  }
</style>
