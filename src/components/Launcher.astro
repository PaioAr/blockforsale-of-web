---
const specs = [
  {
    num: '01',
    title: 'Instalación automática',
    desc: 'Descarga e instala Java, Fabric y la instancia del evento sin configurar nada a mano.',
  },
  {
    num: '02',
    title: 'Login con Microsoft',
    desc: 'OAuth oficial. También funciona en modo offline para cuentas no premium.',
  },
  {
    num: '03',
    title: 'Siempre actualizado',
    desc: 'Al iniciar descarga la última versión del modpack del evento automáticamente.',
  },
];
---

<section id="launcher">
  <div class="section-inner">
    <div class="launcher-grid">

      <!-- Mockup -->
      <div class="launcher-mockup reveal">
        <div class="mockup-scanlines"></div>
        <div class="mockup-bar">
          <div class="dot dot-r"></div>
          <div class="dot dot-y"></div>
          <div class="dot dot-g"></div>
          <span class="mockup-bar-label">BlockForSale Client</span>
        </div>
        <div class="mockup-body">
          <div class="mockup-bg-glow"></div>
          <div class="mockup-version">v1.0.1 — EVENTS EDITION</div>
          <div class="mockup-title">
            BLOCKFORSALE
            <span>CLIENT</span>
          </div>
          <div class="mockup-sub">
            Cliente oficial de BlockForSale Events<br />
            Premium & No Premium
          </div>
          <div class="mockup-card">
            <button class="mockup-btn-ms">Iniciar sesión con Microsoft</button>
            <div class="mockup-sep"><span></span>o<span></span></div>
            <button class="mockup-btn-offline">Continuar sin cuenta (offline)</button>
            <p class="mockup-legal">Al continuar aceptas los términos de BlockForSale Events</p>
          </div>
        </div>
      </div>

      <!-- Info -->
      <div class="launcher-info reveal reveal-delay">
        <span class="section-tag">Launcher oficial</span>
        <h2 class="launcher-title">BLOCK<br />FOR<br />SALE<br />CLIENT</h2>

        <div class="specs">
          {specs.map(({ num, title, desc }) => (
            <div class="spec">
              <div class="spec-num">{num}</div>
              <div class="spec-bar"></div>
              <div class="spec-body">
                <h4>{title}</h4>
                <p>{desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="launcher-dl">
          <a href="#" class="btn-primary">
            Descargar para Windows <span>↓</span>
          </a>
          <span class="dl-note">Windows 10 / 11 · Gratis</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  section {
    padding: 130px 0;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(204,27,27,0.3), transparent);
  }

  .launcher-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  /* Mockup */
  .launcher-mockup {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    box-shadow:
      0 0 0 1px rgba(0,0,0,0.5),
      0 40px 80px rgba(0,0,0,0.6),
      0 0 60px rgba(204,27,27,0.08);
  }

  .mockup-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0,0,0,0.04) 3px,
      rgba(0,0,0,0.04) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  .mockup-bar {
    background: rgba(0,0,0,0.5);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 7px;
    border-bottom: 0.5px solid var(--border);
    position: relative;
    z-index: 3;
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }

  .mockup-bar-label {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.5px;
    margin-left: 8px;
  }

  .mockup-body {
    padding: 52px 32px 44px;
    text-align: center;
    position: relative;
  }

  .mockup-bg-glow {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(204,27,27,0.1) 0%, transparent 70%);
    pointer-events: none;
    animation: mg 4s ease-in-out infinite;
  }

  @keyframes mg {
    0%,100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }

  .mockup-version {
    display: inline-block;
    border: 0.5px solid var(--border-red);
    color: #b06060;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 2px;
    margin-bottom: 22px;
    position: relative;
    z-index: 1;
  }

  .mockup-title {
    font-family: var(--font-display);
    font-size: 46px;
    letter-spacing: 3px;
    line-height: 1;
    color: var(--text);
    text-shadow:
      0 0 40px rgba(204,27,27,0.4),
      0 0 80px rgba(204,27,27,0.15);
    position: relative;
    z-index: 1;
    margin-bottom: 4px;
    filter: drop-shadow(0 0 20px rgba(204,27,27,0.3));
  }

  .mockup-title span {
    display: block;
    color: var(--red);
    text-shadow:
      0 0 30px rgba(204,27,27,0.9),
      0 0 60px rgba(204,27,27,0.4);
  }

  .mockup-sub {
    font-size: 11px;
    color: var(--text-dim);
    margin-bottom: 28px;
    line-height: 1.7;
    letter-spacing: 0.3px;
    position: relative;
    z-index: 1;
  }

  .mockup-card {
    background: rgba(255,255,255,0.025);
    border: 0.5px solid var(--border);
    border-radius: 5px;
    padding: 22px;
    position: relative;
    z-index: 1;
  }

  .mockup-btn-ms {
    background: var(--red);
    color: #fff;
    padding: 13px;
    border-radius: 3px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    display: block;
    width: 100%;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    transition: background 0.2s, box-shadow 0.2s;
  }

  .mockup-btn-ms:hover {
    background: var(--red-dark);
    box-shadow: 0 4px 20px rgba(204,27,27,0.5);
  }

  .mockup-sep {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 12px 0;
    color: var(--text-dim);
    font-size: 11px;
  }
  .mockup-sep span { flex: 1; height: 0.5px; background: var(--border); }

  .mockup-btn-offline {
    background: transparent;
    color: var(--text-muted);
    padding: 12px;
    border-radius: 3px;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.3px;
    display: block;
    width: 100%;
    border: 0.5px solid var(--border);
    cursor: pointer;
    font-family: var(--font-body);
    transition: border-color 0.2s, color 0.2s;
  }

  .mockup-btn-offline:hover { border-color: rgba(255,255,255,0.18); color: var(--text); }

  .mockup-legal {
    font-size: 9px;
    color: var(--text-dim);
    margin-top: 12px;
    letter-spacing: 0.2px;
  }

  /* Info side */
  .launcher-info {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .launcher-title {
    font-family: var(--font-display);
    font-size: clamp(44px, 6vw, 76px);
    line-height: 0.95;
    letter-spacing: 4px;
    color: var(--text);
    filter: drop-shadow(0 0 30px rgba(204,27,27,0.2));
  }

  .specs { display: flex; flex-direction: column; gap: 24px; }

  .spec {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .spec-num {
    font-family: var(--font-display);
    font-size: 30px;
    color: var(--red);
    letter-spacing: 2px;
    line-height: 1;
    flex-shrink: 0;
    width: 36px;
    text-align: right;
  }

  .spec-bar {
    width: 1px;
    background: var(--border-red);
    align-self: stretch;
    flex-shrink: 0;
  }

  .spec-body h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
  }

  .spec-body p {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .launcher-dl {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .dl-note {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.5px;
  }

  @media (max-width: 900px) {
    .launcher-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
